# Production env contract for Vercel.
# Set these in the Vercel project dashboard under Settings, Environment Variables.
# Real values stay out of git. Do not copy this file to .env.

DATABASE_URL=postgres://user:****@ep-xxxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
SESSION_SECRET=__paste_a_64_hex_string__
CLIENT_ORIGIN=https://todo.vercel.app

# NODE_ENV is set automatically by Vercel to "production" for production builds.
# PORT is not used because the Express app runs as a serverless function, not a long-lived listener.
